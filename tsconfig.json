{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "node"],
    "useDefineForClassFields": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "demo/vite.config.ts"
  ]
}
