{
  "name": "haori-bootstrap",
  "version": "0.2.0",
  "description": "Bootstrap-based UI extension library for Haori.js.",
  "type": "module",
  "main": "./dist/haori-bootstrap.js",
  "module": "./dist/haori-bootstrap.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/haori-bootstrap.js",
      "default": "./dist/haori-bootstrap.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predev:demo": "npm run build",
    "dev:demo": "vite --config demo/vite.config.ts",
    "prebuild:demo": "npm run build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "prepreview:demo": "npm run build:demo",
    "preview:demo": "vite preview --config demo/vite.config.ts",
    "test": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "pretest:e2e:headed": "npm run build",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,tests,demo}/**/*.{ts,js,json,html}\"",
    "format:check": "prettier --check \"{src,tests,demo}/**/*.{ts,js,json,html}\"",
    "type-check": "tsc --noEmit",
    "compile": "npm run type-check",
    "version": "node ./scripts/sync-version.mjs && git add src/index.ts README.md README.ja.md demo/cdn.html demo/cdn.js playwright/demo.spec.ts package.json package-lock.json",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meibinlab/haori-js-bootstrap.git"
  },
  "keywords": [
    "haori",
    "bootstrap",
    "ui-extension",
    "frontend"
  ],
  "author": "meibinlab",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/meibinlab/haori-js-bootstrap/issues"
  },
  "homepage": "https://github.com/meibinlab/haori-js-bootstrap#readme",
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.7.5",
    "eslint": "^9.31.0",
    "globals": "^15.9.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  }
}
